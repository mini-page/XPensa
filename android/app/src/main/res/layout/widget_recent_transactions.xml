<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget 2 — Recent Transactions Widget
  Recommended size: 4 × 4 launcher cells (~250 × 250 dp)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_rounded_bg"
    android:padding="12dp">

    <!-- ── Filter bar ──────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/widget_rt_filter_today"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_chip_selected_bg"
            android:textColor="@color/widget_chip_selected_text" />

        <TextView
            android:id="@+id/widget_rt_filter_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Week"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_chip_unselected_bg"
            android:textColor="@color/widget_chip_unselected_text" />

        <TextView
            android:id="@+id/widget_rt_filter_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Month"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/widget_chip_unselected_bg"
            android:textColor="@color/widget_chip_unselected_text" />

        <android.widget.Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/widget_rt_open_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Open &#8599;"
            android:textColor="@color/widget_open_app_text"
            android:textSize="10sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ── Divider ────────────────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/widget_divider"
        android:layout_marginBottom="4dp" />

    <!-- ── Empty state ───────────────────────────────────────── -->
    <TextView
        android:id="@+id/widget_rt_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No transactions.\nOpen XPensa to get started."
        android:textColor="@color/widget_text_muted"
        android:textSize="11sp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- ── Transaction rows (0–4) ─────────────────────────────── -->

    <!-- Row 0 -->
    <LinearLayout
        android:id="@+id/widget_rt_row_0"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_rt_row_0_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:textSize="14sp"
            android:background="@drawable/widget_icon_circle_bg"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_rt_row_0_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_dark"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_rt_row_0_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_muted"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <TextView
            android:id="@+id/widget_rt_row_0_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1" />

    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/widget_rt_row_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_rt_row_1_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:textSize="14sp"
            android:background="@drawable/widget_icon_circle_bg"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_rt_row_1_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_dark"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_rt_row_1_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_muted"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <TextView
            android:id="@+id/widget_rt_row_1_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1" />

    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:id="@+id/widget_rt_row_2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_rt_row_2_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:textSize="14sp"
            android:background="@drawable/widget_icon_circle_bg"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_rt_row_2_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_dark"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_rt_row_2_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_muted"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <TextView
            android:id="@+id/widget_rt_row_2_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1" />

    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:id="@+id/widget_rt_row_3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_rt_row_3_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:textSize="14sp"
            android:background="@drawable/widget_icon_circle_bg"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_rt_row_3_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_dark"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_rt_row_3_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_muted"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <TextView
            android:id="@+id/widget_rt_row_3_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1" />

    </LinearLayout>

    <!-- Row 4 -->
    <LinearLayout
        android:id="@+id/widget_rt_row_4"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/widget_rt_row_4_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:textSize="14sp"
            android:background="@drawable/widget_icon_circle_bg"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_rt_row_4_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_dark"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_rt_row_4_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_muted"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <TextView
            android:id="@+id/widget_rt_row_4_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1" />

    </LinearLayout>

    <!-- ── "and N more…" footer ──────────────────────────────── -->
    <TextView
        android:id="@+id/widget_rt_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/widget_more_text"
        android:textSize="9sp"
        android:gravity="center"
        android:layout_marginTop="2dp"
        android:visibility="gone" />

</LinearLayout>
